# ─── Database ─────────────────────────────────────────────
# Neon PostgreSQL — get your connection string from https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/hospital_analytics?sslmode=require"

# ─── App ──────────────────────────────────────────────────
# Base URL for internal API calls (set to your Vercel domain in production)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Optional: Force Neon adapter locally ─────────────────
# USE_NEON_ADAPTER="true"
